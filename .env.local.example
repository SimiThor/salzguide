# SalzGuide – Environment-Variablen (Vorlage)
#
# Setup:  cp .env.local.example .env.local   und echte Werte eintragen.
# .env.local wird NIE committet (siehe .gitignore). Diese Datei enthält nur Keys,
# niemals Werte — sie ist die gemeinsame Referenz im Team.
#
# Neue Variable im Code? Immer HIER mit eintragen (ohne Wert), damit alle wissen,
# dass es sie gibt.

# === Basis ===
# Lokal: http://localhost:3000 · Produktion: https://salzguide.com
NEXT_PUBLIC_SITE_URL=

# === Supabase (EU / Frankfurt) — PFLICHT, sonst startet die App nicht ===
# Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Nur serverseitig! Umgeht Row Level Security — niemals im Client verwenden.
SUPABASE_SERVICE_ROLE_KEY=

# === Mapbox (Explore-Karte) — PFLICHT für die Karte ===
# mapbox.com -> Account -> Tokens (Public Token, beginnt mit "pk.")
NEXT_PUBLIC_MAPBOX_TOKEN=

# === Stripe (Membership) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TAX_ENABLED=

# === Cloudflare Turnstile (Bot-Schutz am Login) ===
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# === Externe APIs ===
# Wetter läuft über Open-Meteo (kein Key nötig).
# Google Places (Öffnungszeiten)
GOOGLE_PLACES_KEY=
# OpenRouteService (Wanderwege-Snapping) — https://openrouteservice.org/dev
ORS_KEY=

# === E-Mail (Magic-Link, Widerruf-/System-Mails) ===
RESEND_KEY=
# Format: "SalzGuide <no-reply@deine-verifizierte-domain.at>"
EMAIL_FROM=

# === Claude / Anthropic (KI-Texte im Admin) ===
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# === ElevenLabs (AudioTour) ===
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Stimm-Feintuning (optional, Code nutzt Defaults wenn leer)
ELEVENLABS_STABILITY=
ELEVENLABS_SIMILARITY=
ELEVENLABS_STYLE=
ELEVENLABS_SPEED=
ELEVENLABS_SPEAKER_BOOST=

# === Cron-Endpunkte absichern (frei wählbares langes Secret) ===
CRON_SECRET=
