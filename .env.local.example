# SalzGuide – Environment-Variablen (Vorlage)
#
# Setup:  cp .env.local.example .env.local   und echte Werte eintragen.
# .env.local wird NIE committet (siehe .gitignore). Diese Datei enthält nur Keys,
# niemals Werte — sie ist die gemeinsame Referenz im Team.
#
# Neue Variable im Code? Immer HIER mit eintragen (ohne Wert), damit alle wissen,
# dass es sie gibt.

# === Basis ===
# LOKAL: http://localhost:3000
#
# IN VERCEL: am besten GAR NICHT setzen. lib/site-url.ts nimmt dann Vercels eigene
# VERCEL_PROJECT_PRODUCTION_URL — die zeigt immer auf die aktuelle Produktions-Domain und
# wandert beim Umzug von selbst mit. Wer hier trotzdem etwas einträgt, muss es beim
# Domainwechsel daran denken.
#
# WARUM DER HINWEIS SO AUSFÜHRLICH IST: Hier stand mal "Produktion: https://salzguide.com",
# und in Vercel landete "http://localhost:3000". Folge: Der Magic-Link zeigte auf localhost
# (niemand kam auf der echten Seite rein), robots.txt und sitemap.xml auch, und jede Seite
# sagte Google per canonical, ihr Original stehe auf localhost. Kein Fehler, kein Alarm,
# monatelang. lib/site-url.ts verwirft localhost auf Vercel inzwischen — aber der Riegel
# ersetzt das Geländer nicht.
NEXT_PUBLIC_SITE_URL=

# === Supabase (EU / Frankfurt) — PFLICHT, sonst startet die App nicht ===
# Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Nur serverseitig! Umgeht Row Level Security — niemals im Client verwenden.
SUPABASE_SERVICE_ROLE_KEY=

# === Mapbox (Explore-Karte) — PFLICHT für die Karte ===
# mapbox.com -> Account -> Tokens (Public Token, beginnt mit "pk.")
NEXT_PUBLIC_MAPBOX_TOKEN=

# === Stripe (Membership) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TAX_ENABLED=

# === Cloudflare Turnstile (Bot-Schutz am Login) ===
#
# LOKAL: LEER LASSEN. Das ist kein Versehen, sondern der einzige Weg, der funktioniert.
#
# Echte Turnstile-Keys sind bei Cloudflare an Domains gebunden, und localhost steht dort
# nicht drin. Trägt man sie hier ein, schlägt das Widget beim Anmelden fehl, der Server
# blockt (turnstile.ts blockt im Zweifel, absichtlich) — und man sperrt sich auf dem
# eigenen Rechner selbst aus. Genau das ist passiert, und die Suche danach dauerte lang,
# weil nichts kaputt AUSSIEHT: Der Roboter-Check sagt nur, er klappe gerade nicht.
#
# Leer = Gate aus (turnstile.ts:25). Lokal richtig, in Produktion beide setzen.
#
# Wer localhost trotzdem testen will, muss es in der Cloudflare-Widget-Konfiguration als
# erlaubte Domain eintragen. Lohnt nur, wenn man am Bot-Schutz selbst arbeitet.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# === Externe APIs ===
# Wetter läuft über Open-Meteo (kein Key nötig).
# Google Places (Öffnungszeiten)
GOOGLE_PLACES_KEY=
# OpenRouteService (Wanderwege-Snapping) — https://openrouteservice.org/dev
ORS_KEY=

# === E-Mail (Magic-Link, Widerruf-/System-Mails) ===
RESEND_KEY=
# Format: "SalzGuide <no-reply@deine-verifizierte-domain.at>"
EMAIL_FROM=

# === Claude / Anthropic (KI-Texte im Admin) ===
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# === ElevenLabs (AudioTour) ===
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Stimm-Feintuning (optional, Code nutzt Defaults wenn leer)
ELEVENLABS_STABILITY=
ELEVENLABS_SIMILARITY=
ELEVENLABS_STYLE=
ELEVENLABS_SPEED=
ELEVENLABS_SPEAKER_BOOST=

# === Cron-Endpunkte absichern (frei wählbares langes Secret) ===
CRON_SECRET=

# === Intro-Video-Renderer (/render/intro) absichern ===
# Frei wählbares langes Secret. Schützt die interne 3D-Render-Seite in Produktion
# (?token=...). LOKAL egal: im Dev-Server ist /render/intro ohne Token offen.
RENDER_SECRET=
