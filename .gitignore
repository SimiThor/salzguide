# misc
.DS_Store
*.pem
tsconfig.tsbuildinfo

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets
.env
.env*.local
.env.development
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo

# supabase
/supabase/.temp
/supabase/.branches

# Rollback-Protokolle einmaliger Storage-Migrationen (enthalten konkrete Objektpfade,
